# Скопируйте в .env и заполните реальными значениями перед `docker compose up`.
# .env в .gitignore — не коммитится.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=markettj

# Пусто по умолчанию — AI-ассистент (раздел 3/38 ТЗ) работать не будет без ключа,
# остальной функционал не зависит от него.
ANTHROPIC_API_KEY=

# Секрет для подписи JWT (раздел 16 ТЗ). В проде — обязательно заменить
# на случайную строку от 32 символов, никогда не использовать дефолт ниже.
JWT_SECRET=dev-secret-change-in-production-32chars-min
